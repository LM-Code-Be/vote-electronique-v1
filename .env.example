APP_ENV=local
APP_BASE_PATH=/vote
APP_TIMEZONE=Europe/Paris

DB_HOST=localhost
DB_NAME=vote_electronique
DB_USER=root
DB_PASS=
DB_CHAR=utf8mb4
# Optionnel: chemin absolu vers mysqldump (ex: C:\\wamp64\\bin\\mysql\\mysql8.0.31\\bin\\mysqldump.exe)
MYSQLDUMP_BIN=mysqldump

# Enterprise: les comptes sont gérés via `users` + `roles`
# Premier compte recommandé:
# php scripts/user_create.php --username=superadmin --password=DemoPass123! --roles=SUPERADMIN,ADMIN,SCRUTATEUR,VOTER --user_type=INTERNAL

UPLOAD_MAX_BYTES=5242880

# Session / authentification enterprise
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=12
# En production HTTPS: mettre 1
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
LOGIN_RATE_WINDOW_SECONDS=900
LOGIN_RATE_MAX_FAILURES=10

# Maintenance (bloque les dépôts de vote)
MAINTENANCE=0
